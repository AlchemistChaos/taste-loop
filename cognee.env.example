# Cognee configuration — copy to `.env` in the process/dir where Cognee runs (the memory page only).
# Ollama is a global system service; models live in ~/.ollama (NOT in this repo).
# Verified installed on this machine: glm-4.7-flash:latest (LLM) + nomic-embed-text:latest (embeddings).

# --- Cognee's LLM: graph extraction (cognify) + distillation (curator/writer) → local Ollama / GLM ---
LLM_PROVIDER="ollama"
LLM_MODEL="glm-4.7-flash:latest"
LLM_ENDPOINT="http://localhost:11434/v1"     # note the /v1
LLM_API_KEY="ollama"                         # dummy value, but must be non-empty

# --- Cognee's embeddings (recall / vector search) → local Ollama / nomic-embed-text ---
EMBEDDING_PROVIDER="ollama"
EMBEDDING_MODEL="nomic-embed-text"
EMBEDDING_ENDPOINT="http://localhost:11434/api/embeddings"
EMBEDDING_DIMENSIONS=768                      # must match nomic-embed-text

# If Cognee runs inside Docker, replace localhost with host.docker.internal in both endpoints.
#
# Install Cognee pinned to PR #3107 (session memory + distillation):
#   pip install "git+https://github.com/topoteretes/cognee.git@c505f326ddb46d8bcc15f963c29ce5c7ccc2053d"
#
# ⚠ Day-1 smoke test (the "Lessons" counter depends on this): confirm glm-4.7-flash can emit the
#   strict JSON cognify/distill_session need. Small local models often can't. If it fails, point
#   Cognee's LLM at a bigger/hosted model (site-building stays on Codex; A/B fairness unaffected).
